{% comment %}
  Modern collection-style product card.
{% endcomment %}

{%- unless skip_styles -%}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if card_product and card_product != empty -%}
  {%- liquid
    assign primary_media = card_product.featured_media
    assign alternate_media = card_product.media[1]
    assign swatch_option = blank
    assign swatch_option_position = 0
    for option in card_product.options_with_values
      assign option_name = option.name | downcase
      if option_name contains 'color' or option_name contains 'renk' or option_name contains 'metal'
        assign swatch_option = option
        assign swatch_option_position = forloop.index
        break
      endif
    endfor

    assign unique_key = section_id | default: 'card' | append: '-' | append: card_product.id
    assign default_swatch_name = ''
    if swatch_option != blank
      assign swatch_option_index = swatch_option_position | minus: 1
      assign default_swatch_name = card_product.selected_or_first_available_variant.options[swatch_option_index]
    endif
  -%}

  <div class="modern-collection-container">
    <div class="ProductItem">
      <div class="ProductItem__Wrapper">
        <a
          href="{{ card_product.url }}"
          class="ProductItem__ImageWrapper{% if alternate_media != blank %} ProductItem__ImageWrapper--withAlternateImage{% endif %}"
          style="font-size: 0;"
          aria-label="{{ card_product.title | escape }}"
        >
          <div class="ProductItem__ImageFrame ProductItem__ImageFrame--desktop" style="--aspect-ratio: 4/5;">
            {%- if alternate_media != blank -%}
              <div class="ProductItem__ImageLayer ProductItem__ImageLayer--alternate">
                {{
                  alternate_media
                  | image_url: width: 1200
                  | image_tag:
                    widths: '320, 480, 640, 900, 1200',
                    sizes: '(min-width: 1200px) 25vw, (min-width: 750px) 33vw, 50vw',
                    class: 'ProductItem__Image ProductItem__Image--alternate',
                    loading: 'lazy',
                    alt: alternate_media.alt | default: card_product.title
                }}
              </div>
            {%- endif -%}

            <div class="ProductItem__ImageLayer ProductItem__ImageLayer--primary">
              {%- if primary_media != blank -%}
                {{
                  primary_media
                  | image_url: width: 1200
                  | image_tag:
                    widths: '320, 480, 640, 900, 1200',
                    sizes: '(min-width: 1200px) 25vw, (min-width: 750px) 33vw, 50vw',
                    class: 'ProductItem__Image ProductItem__Image--primary',
                    loading: 'lazy',
                    alt: primary_media.alt | default: card_product.title,
                    id: 'ProductPrimaryImage-' | append: unique_key
                }}
              {%- else -%}
                {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg ProductItem__Image ProductItem__Image--primary' }}
              {%- endif -%}
            </div>
          </div>
        </a>

        <div class="ProductItem__Info ProductItem__Info--left">
          <h3 class="product__title_">
            <a class="modern-coll-title" href="{{ card_product.url }}">{{ card_product.title | escape }}</a>
          </h3>

          <div class="ProductItem__PriceList Heading">
            {% render 'price', product: card_product, price_class: 'modern-coll-title', show_compare_at_price: false %}
          </div>

          {%- if swatch_option != blank and swatch_option.values.size > 0 -%}
            <div class="ProductItem__ColorSwatchList" data-product-card-swatches>
              {%- for value in swatch_option.values limit: 6 -%}
                {%- liquid
                  assign option_index = swatch_option_position | minus: 1
                  assign matched_variant = blank
                  for variant in card_product.variants
                    if variant.options[option_index] == value
                      assign matched_variant = variant
                      break
                    endif
                  endfor

                  assign variant_image = matched_variant.featured_media | default: primary_media
                  assign swatch_color = '#D9D9D9'
                  assign value_downcase = value | downcase

                  case value_downcase
                    when 'yellow', 'gold', 'yellow gold'
                      assign swatch_color = '#E6CA97'
                    when 'white', 'white gold'
                      assign swatch_color = '#D9D9D9'
                    when 'rose', 'rose gold', 'pink'
                      assign swatch_color = '#E1A4A9'
                    when 'silver'
                      assign swatch_color = '#C7CCD1'
                    when 'black'
                      assign swatch_color = '#1F1F1F'
                  endcase
                -%}

                <div class="ProductItem__ColorSwatchItem">
                  <input
                    class="ColorSwatch__Radio"
                    type="radio"
                    name="Swatch-{{ unique_key }}"
                    id="Swatch-{{ unique_key }}-{{ forloop.index }}"
                    value="{{ value | escape }}"
                    {% if forloop.first %}
                      checked="checked"
                    {% endif %}
                    data-image-target="ProductPrimaryImage-{{ unique_key }}"
                    data-image-src="{{ variant_image | image_url: width: 1200 }}"
                    data-image-srcset="
                      {{ variant_image | image_url: width: 320 }} 320w,
                      {{ variant_image | image_url: width: 480 }} 480w,
                      {{ variant_image | image_url: width: 640 }} 640w,
                      {{ variant_image | image_url: width: 900 }} 900w,
                      {{ variant_image | image_url: width: 1200 }} 1200w
                    "
                    data-image-alt="{{ variant_image.alt | default: card_product.title | escape }}"
                  >
                  <label
                    class="ColorSwatch ColorSwatch--small"
                    for="Swatch-{{ unique_key }}-{{ forloop.index }}"
                    title="{{ value | escape }}"
                    data-tooltip="{{ value | escape }}"
                    style="--swatch-color: {{ swatch_color }};"
                  ></label>
                </div>
              {%- endfor -%}

              <div class="ProductItem__ColorSwatchName modern-coll-color" data-swatch-name>
                {{ default_swatch_name | default: swatch_option.values.first | escape }}
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  <style>
    .modern-collection-container .ProductItem {
      visibility: inherit;
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }

    .ProductItem__Wrapper {
      display: flex;
      flex-direction: column;
      background: transparent;
    }

    .ProductItem__ImageWrapper {
      text-decoration: none;
      display: block;
    }

    .ProductItem__ImageFrame {
      position: relative;
      overflow: hidden;
      background: #f7f7f7;
      aspect-ratio: var(--aspect-ratio, 4/5);
    }

    .ProductItem__ImageLayer {
      position: absolute;
      inset: 0;
      overflow: hidden;
      transition: opacity 0.3s ease;
    }

    .ProductItem__ImageLayer--primary {
      z-index: 1;
      opacity: 1;
    }

    .ProductItem__ImageLayer--alternate {
      z-index: 2;
      opacity: 0;
    }

    @media screen and (min-width: 641px) {
      .ProductItem__ImageWrapper--withAlternateImage:hover .ProductItem__ImageLayer--primary {
        opacity: 0;
      }

      .ProductItem__ImageWrapper--withAlternateImage:hover .ProductItem__ImageLayer--alternate {
        opacity: 1;
      }
    }

    .ProductItem__ImageFrame .ProductItem__Image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
      object-fit: contain;
      object-position: center;
      backface-visibility: hidden;
      transform: translateZ(0);
    }

    .ProductItem__Info {
      padding: 1.2rem;
      padding-bottom: 2rem;
    }

    .product__title_ {
      margin: 0;
      font-size: 1.3rem;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      color: #000;
      line-height: 1.3;
    }

    .modern-coll-title {
      color: #291601f5;
      text-decoration: none;
      font-size: 1.3rem;
      letter-spacing: 0.02em;
    }

    .ProductItem__PriceList {
      margin-top: 0.5rem;
    }

    .ProductItem__ColorSwatchList {
      margin-top: 0.8rem;
      display: flex;
      align-items: center;
      gap: 0.8rem;
      flex-wrap: wrap;
    }

    .ProductItem__ColorSwatchItem {
      display: inline-flex;
      align-items: center;
    }

    .ColorSwatch__Radio {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .ColorSwatch {
      width: 12px;
      height: 12px;
      border-radius: 0;
      display: inline-block;
      background: var(--swatch-color, #d9d9d9);
      border: 1px solid rgba(0, 0, 0, 0.25);
      cursor: pointer;
    }

    .ColorSwatch__Radio:checked + .ColorSwatch {
      outline: 1px solid #111;
      outline-offset: 2px;
    }

    .modern-coll-color {
      font-size: 10px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #111;
    }
  </style>

  <script>
    if (!window.__modernCollectionCardSwatchInit) {
      window.__modernCollectionCardSwatchInit = true;
      document.addEventListener('change', function(event) {
        var input = event.target;
        if (!input.classList.contains('ColorSwatch__Radio')) return;

        var imageId = input.getAttribute('data-image-target');
        var image = document.getElementById(imageId);
        if (image) {
          image.setAttribute('src', input.getAttribute('data-image-src'));
          image.setAttribute('srcset', input.getAttribute('data-image-srcset'));
          image.setAttribute('alt', input.getAttribute('data-image-alt'));
        }

        var swatchList = input.closest('[data-product-card-swatches]');
        if (!swatchList) return;

        var name = swatchList.querySelector('[data-swatch-name]');
        if (name) {
          name.textContent = input.value;
        }
      });
    }
  </script>
{%- else -%}
  <div class="modern-collection-container">
    <div class="ProductItem">
      <div class="ProductItem__ImageFrame" style="--aspect-ratio: 4/5;">
        {{ placeholder_image | default: 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg ProductItem__Image' }}
      </div>
    </div>
  </div>
{%- endif -%}
