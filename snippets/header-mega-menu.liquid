{% comment %}
  Renders a megamenu for the header.

  Usage:
  {% render 'header-mega-menu' %}
{% endcomment %}
{%- liquid
  assign customer_type = customer.metafields.custom.musteri_tipi.value | default: customer.metafields.custom.musteri_tipi | downcase | strip
  assign is_corporate_customer = false
  if customer
    if customer_type contains 'kurumsal'
      assign is_corporate_customer = true
    endif
    for customer_tag in customer.tags
      assign customer_tag_normalized = customer_tag | downcase | strip
      if customer_tag_normalized contains 'kurumsal'
        assign is_corporate_customer = true
      endif
    endfor
  endif
-%}

{%- style -%}
  .mega-menu__panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .mega-menu__promo {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    min-height: 22rem;
    aspect-ratio: 16 / 9;
    background: rgba(var(--color-foreground), 0.04);
  }

  .mega-menu__promo-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transform: scale(1);
    transition: opacity 0.28s ease, transform 0.42s ease;
  }

  .mega-menu__promo-image.is-changing {
    opacity: 0;
    transform: scale(1.04);
  }

  .mega-menu__promo-image.is-visible {
    opacity: 1;
    transform: scale(1);
  }

  .mega-menu__promo-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 1.4rem;
    background: linear-gradient(180deg, rgba(16, 12, 9, 0.06), rgba(16, 12, 9, 0.56));
  }

  .mega-menu__promo-title {
    margin: 0;
    color: #fff;
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    font-weight: 600;
  }

  @media screen and (min-width: 990px) {
    .mega-menu__panel.mega-menu__panel--has-promo {
      grid-template-columns: minmax(0, 1fr) minmax(24rem, 34rem);
    }
  }
{%- endstyle -%}

<script>
  if (!window.__megaMenuCollectionPreviewInit) {
    window.__megaMenuCollectionPreviewInit = true;

    document.addEventListener('mouseover', function(event) {
      var trigger = event.target.closest('[data-mega-preview-link]');
      if (!trigger) return;

      var panel = trigger.closest('.mega-menu__panel');
      if (!panel) return;

      var preview = panel.querySelector('[data-mega-preview]');
      var image = panel.querySelector('.mega-menu__promo-image');
      var title = panel.querySelector('[data-mega-preview-title]');
      if (!preview || !image) return;

      var src = trigger.getAttribute('data-preview-src');
      if (!src) return;
      if (image.getAttribute('src') === src) return;

      image.classList.remove('is-visible');
      image.classList.add('is-changing');

      window.setTimeout(function() {
        image.removeAttribute('srcset');
        image.src = src;
        image.alt = trigger.getAttribute('data-preview-alt') || trigger.textContent.trim();
        preview.href = trigger.getAttribute('data-preview-url') || trigger.href;

        if (title) {
          title.textContent = trigger.getAttribute('data-preview-title') || trigger.textContent.trim();
        }

        image.classList.remove('is-changing');
        image.classList.add('is-visible');
      }, 140);
    });

    document.addEventListener('focusin', function(event) {
      var trigger = event.target.closest('[data-mega-preview-link]');
      if (trigger) {
        trigger.dispatchEvent(new MouseEvent('mouseover', { bubbles: true }));
      }
    });
  }
</script>

<nav class="header__inline-menu">
  <ul class="list-menu list-menu--inline" role="list">
    {%- for link in section.settings.menu.links -%}
      {%- liquid
        assign link_is_wholesale = false
        assign render_link = true
        if link.handle == 'toptan-satis' or link.url contains '/collections/toptan-satis'
          assign link_is_wholesale = true
        endif
        if link_is_wholesale and is_corporate_customer == false
          assign render_link = false
        endif
        assign promo_block = blank
        assign collection_image = blank
        assign collection_image_alt = link.title
        assign first_preview_image = blank
        assign first_preview_title = blank
        assign first_preview_url = blank
        if link.type == 'collection_link' and link.object != blank
          assign collection_image = link.object.image | default: link.object.featured_image
          if collection_image != blank
            assign collection_image_alt = collection_image.alt | default: link.title
          endif
        endif
        for block in section.blocks
          if block.type == 'mega_menu_promo' and block.settings.parent_menu_handle == link.handle
            assign promo_block = block
            break
          endif
        endfor
        for childlink in link.links
          assign childlink_is_wholesale = false
          if childlink.handle == 'toptan-satis' or childlink.url contains '/collections/toptan-satis'
            assign childlink_is_wholesale = true
          endif
          unless childlink_is_wholesale and is_corporate_customer == false
            if first_preview_image == blank and childlink.type == 'collection_link' and childlink.object != blank
              assign child_collection_image = childlink.object.image | default: childlink.object.featured_image
              if child_collection_image != blank
                assign first_preview_image = child_collection_image
                assign first_preview_title = childlink.title
                assign first_preview_url = childlink.url
              endif
            endif
            for grandchildlink in childlink.links
              assign grandchildlink_is_wholesale = false
              if grandchildlink.handle == 'toptan-satis' or grandchildlink.url contains '/collections/toptan-satis'
                assign grandchildlink_is_wholesale = true
              endif
              unless grandchildlink_is_wholesale and is_corporate_customer == false
                if first_preview_image == blank and grandchildlink.type == 'collection_link' and grandchildlink.object != blank
                  assign grandchild_collection_image = grandchildlink.object.image | default: grandchildlink.object.featured_image
                  if grandchild_collection_image != blank
                    assign first_preview_image = grandchild_collection_image
                    assign first_preview_title = grandchildlink.title
                    assign first_preview_url = grandchildlink.url
                  endif
                endif
              endunless
            endfor
          endunless
        endfor
        assign preview_image = promo_block.settings.promo_image | default: collection_image | default: first_preview_image
        assign preview_title = promo_block.settings.promo_title | default: link.title | default: first_preview_title
        assign preview_url = promo_block.settings.promo_link | default: link.url | default: first_preview_url
      -%}
      {%- if render_link -%}
        <li>
        {%- if link.links != blank -%}
          <header-menu>
            <details id="Details-HeaderMenu-{{ forloop.index }}" class="mega-menu">
              <summary
                id="HeaderMenu-{{ link.handle }}"
                class="header__menu-item list-menu__item link focus-inset"
              >
                <span
                  {%- if link.child_active %}
                    class="header__active-menu-item"
                  {% endif %}
                >
                  {{- link.title | escape -}}
                </span>
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </summary>
              <div
                id="MegaMenu-Content-{{ forloop.index }}"
                class="mega-menu__content color-{{ section.settings.menu_color_scheme }} gradient motion-reduce global-settings-popup"
                tabindex="-1"
              >
                <div class="mega-menu__panel page-width{% if preview_image != blank %} mega-menu__panel--has-promo{% endif %}">
                  <ul
                    class="mega-menu__list{% if link.levels == 1 %} mega-menu__list--condensed{% endif %}"
                    role="list"
                  >
                    {%- for childlink in link.links -%}
                      {%- liquid
                        assign childlink_is_wholesale = false
                        assign render_childlink = true
                        assign child_preview_image = blank
                        if childlink.handle == 'toptan-satis' or childlink.url contains '/collections/toptan-satis'
                          assign childlink_is_wholesale = true
                        endif
                        if childlink_is_wholesale and is_corporate_customer == false
                          assign render_childlink = false
                        endif
                        if childlink.type == 'collection_link' and childlink.object != blank
                          assign child_preview_image = childlink.object.image | default: childlink.object.featured_image
                        endif
                      -%}
                      {%- if render_childlink -%}
                        <li>
                        <a
                          id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                          href="{{ childlink.url }}"
                          class="mega-menu__link mega-menu__link--level-2 link{% if childlink.current %} mega-menu__link--active{% endif %}"
                          {% if child_preview_image != blank %}
                            data-mega-preview-link
                            data-preview-src="{{ child_preview_image | image_url: width: 900 }}"
                            data-preview-alt="{{ child_preview_image.alt | default: childlink.title | escape }}"
                            data-preview-title="{{ childlink.title | escape }}"
                            data-preview-url="{{ childlink.url }}"
                          {% endif %}
                          {% if childlink.current %}
                            aria-current="page"
                          {% endif %}
                        >
                          {{ childlink.title | escape }}
                        </a>
                        {%- if childlink.links != blank -%}
                          <ul class="list-unstyled" role="list">
                            {%- for grandchildlink in childlink.links -%}
                              {%- liquid
                                assign grandchildlink_is_wholesale = false
                                assign render_grandchildlink = true
                                assign grandchild_preview_image = blank
                                if grandchildlink.handle == 'toptan-satis' or grandchildlink.url contains '/collections/toptan-satis'
                                  assign grandchildlink_is_wholesale = true
                                endif
                                if grandchildlink_is_wholesale and is_corporate_customer == false
                                  assign render_grandchildlink = false
                                endif
                                if grandchildlink.type == 'collection_link' and grandchildlink.object != blank
                                  assign grandchild_preview_image = grandchildlink.object.image | default: grandchildlink.object.featured_image
                                endif
                              -%}
                              {%- if render_grandchildlink -%}
                                <li>
                                <a
                                  id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                  href="{{ grandchildlink.url }}"
                                  class="mega-menu__link link{% if grandchildlink.current %} mega-menu__link--active{% endif %}"
                                  {% if grandchild_preview_image != blank %}
                                    data-mega-preview-link
                                    data-preview-src="{{ grandchild_preview_image | image_url: width: 900 }}"
                                    data-preview-alt="{{ grandchild_preview_image.alt | default: grandchildlink.title | escape }}"
                                    data-preview-title="{{ grandchildlink.title | escape }}"
                                    data-preview-url="{{ grandchildlink.url }}"
                                  {% endif %}
                                  {% if grandchildlink.current %}
                                    aria-current="page"
                                  {% endif %}
                                >
                                  {{ grandchildlink.title | escape }}
                                </a>
                                </li>
                              {%- endif -%}
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}
                        </li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>

                  {%- if preview_image != blank -%}
                    <a class="mega-menu__promo" href="{{ preview_url }}" data-mega-preview {{ promo_block.shopify_attributes }}>
                      {{
                        preview_image
                        | image_url: width: 900
                        | image_tag:
                          widths: '320, 480, 640, 900',
                          sizes: '(min-width: 990px) 30rem, 100vw',
                          class: 'mega-menu__promo-image',
                          loading: 'lazy',
                          alt: preview_title | default: collection_image_alt
                      }}
                      {%- if preview_title != blank -%}
                        <span class="mega-menu__promo-overlay">
                          <span class="mega-menu__promo-title" data-mega-preview-title>{{ preview_title | escape }}</span>
                        </span>
                      {%- endif -%}
                    </a>
                  {%- endif -%}
                </div>
              </div>
            </details>
          </header-menu>
        {%- else -%}
          <a
            id="HeaderMenu-{{ link.handle }}"
            href="{{ link.url }}"
            class="header__menu-item list-menu__item link link--text focus-inset"
            {% if link.current %}
              aria-current="page"
            {% endif %}
          >
            <span
              {%- if link.current %}
                class="header__active-menu-item"
              {% endif %}
            >
              {{- link.title | escape -}}
            </span>
          </a>
        {%- endif -%}
        </li>
      {%- endif -%}
    {%- endfor -%}
  </ul>
</nav>
