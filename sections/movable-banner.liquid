{%- style -%}
  #movable-banner-{{ section.id }} {
    position: relative;
    overflow: hidden;
    background: linear-gradient(95deg, #14100c 0%, #221913 52%, #15100c 100%);
    color: #fff7ec;
    border-bottom: 1px solid rgba(255, 247, 234, 0.14);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    isolation: isolate;
  }

  #movable-banner-{{ section.id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 20% 50%, rgba(255, 214, 178, 0.16), transparent 24%),
      radial-gradient(circle at 80% 50%, rgba(255, 214, 178, 0.08), transparent 24%);
    pointer-events: none;
  }

  #movable-banner-{{ section.id }} .marquee {
    display: flex;
    width: max-content;
    will-change: transform;
    animation: marquee-scroll-{{ section.id }} {{ section.settings.duration }}s linear infinite;
  }

  #movable-banner-{{ section.id }}:hover .marquee {
    animation-play-state: paused;
  }

  #movable-banner-{{ section.id }} .marquee__group {
    display: flex;
    align-items: center;
    gap: 2.2rem;
    padding-right: 2.2rem;
    white-space: nowrap;
  }

  #movable-banner-{{ section.id }} .marquee__item {
    display: inline-flex;
    align-items: center;
    gap: 2.2rem;
    font-family: 'Avenir LT Pro', 'Segoe UI', sans-serif;
    font-size: clamp(1rem, 0.75vw, 1.2rem);
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255, 248, 240, 0.96);
    text-decoration: none;
  }

  #movable-banner-{{ section.id }} .marquee__separator {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: rgba(255, 228, 197, 0.88);
    box-shadow: 0 0 0 0.35rem rgba(255, 228, 197, 0.12);
    flex: 0 0 auto;
  }

  #movable-banner-{{ section.id }} .marquee__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 247, 234, 0.22);
    background: rgba(255, 255, 255, 0.06);
    letter-spacing: 0.18em;
  }

  @keyframes marquee-scroll-{{ section.id }} {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  @media screen and (max-width: 749px) {
    #movable-banner-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | plus: 1 }}px;
      padding-bottom: {{ section.settings.padding_bottom | plus: 1 }}px;
    }

    #movable-banner-{{ section.id }} .marquee__group {
      gap: 1.4rem;
      padding-right: 1.4rem;
    }

    #movable-banner-{{ section.id }} .marquee__item {
      gap: 1.4rem;
      letter-spacing: 0.18em;
    }
  }
{%- endstyle -%}

<section id="movable-banner-{{ section.id }}" aria-label="{{ section.settings.aria_label }}">
  <div class="marquee" role="presentation">
    {%- for i in (1..2) -%}
      <div class="marquee__group" aria-hidden="true">
        {%- for block in section.blocks -%}
          {%- if block.settings.text != blank -%}
            {%- if block.settings.link != blank -%}
              <a class="marquee__item" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
                {%- if block.settings.badge != blank -%}
                  <span class="marquee__badge">{{ block.settings.badge | escape }}</span>
                {%- endif -%}
                <span>{{ block.settings.text | escape }}</span>
              </a>
            {%- else -%}
              <div class="marquee__item" {{ block.shopify_attributes }}>
                {%- if block.settings.badge != blank -%}
                  <span class="marquee__badge">{{ block.settings.badge | escape }}</span>
                {%- endif -%}
                <span>{{ block.settings.text | escape }}</span>
              </div>
            {%- endif -%}
            {%- unless forloop.last -%}
              <span class="marquee__separator" aria-hidden="true"></span>
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Movable Banner",
  "tag": "section",
  "class": "movable-banner-section",
  "settings": [
    {
      "type": "text",
      "id": "aria_label",
      "label": "Erişim etiketi",
      "default": "Promosyon bantı"
    },
    {
      "type": "range",
      "id": "duration",
      "label": "Hareket süresi",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "s",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Üst boşluk",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Alt boşluk",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "ticker_message",
      "name": "Mesaj",
      "settings": [
        {
          "type": "text",
          "id": "badge",
          "label": "Rozet",
          "default": "NEW"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Metin",
          "default": "New season arrival - shop the collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Movable Banner",
      "blocks": [
        {
          "type": "ticker_message",
          "settings": {
            "badge": "NEW",
            "text": "New season arrival - shop the collection"
          }
        },
        {
          "type": "ticker_message",
          "settings": {
            "badge": "SKINCARE",
            "text": "Dermatologist tested and barrier-safe formulas"
          }
        },
        {
          "type": "ticker_message",
          "settings": {
            "badge": "GIFT",
            "text": "Premium gift packaging on selected orders"
          }
        }
      ]
    }
  ]
}
{% endschema %}