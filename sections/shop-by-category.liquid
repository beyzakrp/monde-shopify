    {
      "type": "range",
      "id": "heading_size",
      "label": "Başlık Font Boyutu",
      "min": 18,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Başlık Rengi",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Başlık Hizalaması",
      "options": [
        { "value": "left", "label": "Sol" },
        { "value": "center", "label": "Orta" },
        { "value": "right", "label": "Sağ" }
      ],
      "default": "left"
    },
    {
      "type": "text",
