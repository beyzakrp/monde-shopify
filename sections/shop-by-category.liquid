{%- style -%}
  #shop-by-category-{{ section.id }} {
    margin: {{ section.settings.margin_top }}px 0 {{ section.settings.margin_bottom }}px;
    padding: {{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;
  }

  #shop-by-category-{{ section.id }} .shop-by-header {
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.heading_color }};
    text-align: {{ section.settings.heading_alignment }};
    margin: 0 0 28px;
    font-family: '{{ section.settings.heading_font }}', serif;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-wrap: balance;
  }

  #shop-by-category-{{ section.id }} .category-container {
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: auto;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  #shop-by-category-{{ section.id }} .category-container::-webkit-scrollbar {
    display: none;
  }

  #shop-by-category-{{ section.id }} .category-container:active {
    cursor: grabbing;
  }

  #shop-by-category-{{ section.id }} .category-wrapper {
    display: flex;
    gap: {{ section.settings.gap_mobile }}px;
    min-width: min-content;
    padding: 0 2px;
    margin: 0;
  }

  #shop-by-category-{{ section.id }} .category-item {
    flex: 0 0 auto;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #shop-by-category-{{ section.id }} .category-image-wrapper {
    position: relative;
    overflow: hidden;
    width: 318px;
    height: 318px;
    aspect-ratio: 1;
    border-radius: 26px;
  }

  #shop-by-category-{{ section.id }} .category-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
    transition: transform 0.42s ease, filter 0.42s ease;
    filter: saturate(0.92) contrast(1.04);
  }

  #shop-by-category-{{ section.id }} .category-item:hover .category-image {
    transform: scale(1.08);
    filter: saturate(1) contrast(1.08);
  }

  #shop-by-category-{{ section.id }} .category-image-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(19, 14, 9, 0.52) 10%, rgba(19, 14, 9, 0.08) 54%, rgba(19, 14, 9, 0.02) 100%);
    pointer-events: none;
  }

  #shop-by-category-{{ section.id }} .category-label {
    position: absolute;
    bottom: 20px;
    left: 0;
    right: 0;
    text-align: center;
    text-transform: uppercase;
    font-size: {{ section.settings.label_size }}px;
    color: #fff7ea;
    font-family: 'Avenir LT Pro', sans-serif;
    font-weight: 700;
    pointer-events: none;
    letter-spacing: 0.18em;
    text-shadow: 0 4px 14px rgba(0, 0, 0, 0.34);
    display: inline-block;
    z-index: 1;
  }

  #shop-by-category-{{ section.id }} .category-label::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -6px;
    width: max(48px, 60%);
    height: 2px;
    background-color: currentColor;
    transform: translateX(-50%) scaleX(0);
    transform-origin: left center;
    transition: transform 0.35s ease;
  }

  #shop-by-category-{{ section.id }} .category-image-wrapper:hover .category-label::after,
  #shop-by-category-{{ section.id }} .category-item:focus-visible .category-label::after {
    transform: translateX(-50%) scaleX(1);
  }

  @media (min-width: 640px) {
    #shop-by-category-{{ section.id }} .category-image-wrapper {
      width: 384px;
      height: 384px;
    }

    #shop-by-category-{{ section.id }} .category-wrapper {
      gap: {{ section.settings.gap_tablet }}px;
    }
  }

  @media (min-width: 1024px) {
    #shop-by-category-{{ section.id }} .category-image-wrapper {
      width: calc((100vw - 40px - 60px) / 4);
      height: auto;
    }

    #shop-by-category-{{ section.id }} .category-wrapper {
      gap: {{ section.settings.gap_desktop }}px;
    }
  }

  @media (max-width: 768px) {
    #shop-by-category-{{ section.id }} .shop-by-header {
      font-size: {{ section.settings.heading_size | times: 0.8 | round }}px;
    }

    #shop-by-category-{{ section.id }} .category-label {
      letter-spacing: 0.12em;
    }
  }
{%- endstyle -%}

<section id="shop-by-category-{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <h2 class="shop-by-header">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="category-container">
    <div class="category-wrapper">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.collection_link }}" class="category-item">
          <div class="category-image-wrapper">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag:
                class: 'category-image',
                widths: '318, 384, 600',
                sizes: '(min-width: 1024px) calc((100vw - 100px) / 4), (min-width: 640px) 384px, 318px',
                loading: 'lazy',
                alt: block.settings.category_name | default: 'Category'
              }}
            {%- else -%}
              <div class="category-image" style="background: #f0f0f0; display: flex; align-items: center; justify-content: center;">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {%- endif -%}
            <p class="category-label">{{ block.settings.category_name }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% javascript %}
  (function() {
    const sliders = document.querySelectorAll('.shop-by-category-section .category-container');
    if (!sliders.length) return;

    sliders.forEach((slider) => {
      let isDown = false;
      let startX;
      let scrollLeft;
      let isDragging = false;
      const dragThreshold = 5;
      let startY;

      slider.addEventListener('mousedown', (e) => {
        isDown = true;
        slider.style.cursor = 'grabbing';
        startX = e.pageX - slider.offsetLeft;
        startY = e.pageY;
        scrollLeft = slider.scrollLeft;
        isDragging = false;
        e.preventDefault();
      });

      slider.addEventListener('mouseleave', () => {
        isDown = false;
        slider.style.cursor = 'grab';
      });

      slider.addEventListener('mouseup', () => {
        isDown = false;
        slider.style.cursor = 'grab';
      });

      slider.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();

        const x = e.pageX - slider.offsetLeft;
        const y = e.pageY;
        const walkX = Math.abs(x - startX);
        const walkY = Math.abs(y - startY);

        if (walkX > dragThreshold || walkY > dragThreshold) {
          isDragging = true;
        }

        if (isDragging) {
          const walk = (x - startX) * 1.5;
          slider.scrollLeft = scrollLeft - walk;
        }
      });

      slider.closest('.shop-by-category-section')?.querySelectorAll('.category-item').forEach((link) => {
        link.addEventListener('click', function(event) {
          if (isDragging) {
            event.preventDefault();
          }
        });
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Shop by Category",
  "tag": "section",
  "class": "shop-by-category-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Başlık",
      "default": "Bakim Kategorileri"
