{%- style -%}
  #skin-routine-guide-{{ section.id }} {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__inner {
    max-width: min(var(--page-width), 132rem);
    margin: 0 auto;
    padding: 0 1.6rem;
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__header {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(280px, 0.55fr);
    gap: clamp(2rem, 5vw, 7rem);
    align-items: end;
    margin-bottom: clamp(2.6rem, 4vw, 4.8rem);
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__eyebrow {
    margin: 0 0 1rem;
    font-family: 'Avenir LT Pro', Arial, sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__heading {
    margin: 0;
    max-width: 11ch;
    font-family: 'Optima', 'Times New Roman', serif;
    font-size: clamp(4.2rem, 6vw, 8rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 0.96;
    text-wrap: balance;
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__text {
    margin: 0;
    font-family: 'Avenir LT Pro', Arial, sans-serif;
    font-size: clamp(1.5rem, 1.2vw, 1.8rem);
    line-height: 1.7;
    color: rgba({{ section.settings.text_color.red }}, {{ section.settings.text_color.green }}, {{ section.settings.text_color.blue }}, 0.74);
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid rgba({{ section.settings.text_color.red }}, {{ section.settings.text_color.green }}, {{ section.settings.text_color.blue }}, 0.16);
    border-left: 1px solid rgba({{ section.settings.text_color.red }}, {{ section.settings.text_color.green }}, {{ section.settings.text_color.blue }}, 0.16);
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__card {
    min-height: 28rem;
    padding: clamp(1.8rem, 2.2vw, 2.8rem);
    border-right: 1px solid rgba({{ section.settings.text_color.red }}, {{ section.settings.text_color.green }}, {{ section.settings.text_color.blue }}, 0.16);
    border-bottom: 1px solid rgba({{ section.settings.text_color.red }}, {{ section.settings.text_color.green }}, {{ section.settings.text_color.blue }}, 0.16);
    background: rgba(255, 255, 255, 0.42);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2.4rem;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__card:hover,
  #skin-routine-guide-{{ section.id }} .skin-routine__card:focus-visible {
    background: rgba(255, 255, 255, 0.68);
    transform: translateY(-2px);
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__card:focus-visible {
    outline: 2px solid {{ section.settings.accent_color }};
    outline-offset: -2px;
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.4rem;
    height: 3.4rem;
    border: 1px solid rgba({{ section.settings.text_color.red }}, {{ section.settings.text_color.green }}, {{ section.settings.text_color.blue }}, 0.24);
    border-radius: 999px;
    font-size: 1.1rem;
    letter-spacing: 0.12em;
    color: {{ section.settings.accent_color }};
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__card-title {
    margin: 0 0 1rem;
    font-family: 'Optima', 'Times New Roman', serif;
    font-size: clamp(2.4rem, 2vw, 3.2rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.05;
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__card-text {
    margin: 0;
    font-size: 1.45rem;
    line-height: 1.6;
    color: rgba({{ section.settings.text_color.red }}, {{ section.settings.text_color.green }}, {{ section.settings.text_color.blue }}, 0.72);
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__tag {
    display: inline-flex;
    width: fit-content;
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.2rem;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.17em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__footer {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    align-items: center;
    padding-top: 2.4rem;
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__note {
    margin: 0;
    max-width: 62rem;
    color: rgba({{ section.settings.text_color.red }}, {{ section.settings.text_color.green }}, {{ section.settings.text_color.blue }}, 0.72);
    line-height: 1.6;
  }

  #skin-routine-guide-{{ section.id }} .skin-routine__button {
    flex: 0 0 auto;
  }

  @media screen and (max-width: 989px) {
    #skin-routine-guide-{{ section.id }} .skin-routine__header,
    #skin-routine-guide-{{ section.id }} .skin-routine__footer {
      grid-template-columns: 1fr;
      flex-direction: column;
      align-items: flex-start;
    }

    #skin-routine-guide-{{ section.id }} .skin-routine__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 640px) {
    #skin-routine-guide-{{ section.id }} {
      padding: {{ section.settings.padding_top | times: 0.65 | round }}px 0 {{ section.settings.padding_bottom | times: 0.65 | round }}px;
    }

    #skin-routine-guide-{{ section.id }} .skin-routine__grid {
      grid-template-columns: 1fr;
    }

    #skin-routine-guide-{{ section.id }} .skin-routine__card {
      min-height: 22rem;
    }
  }
{%- endstyle -%}

<section id="skin-routine-guide-{{ section.id }}">
  <div class="skin-routine__inner">
    <div class="skin-routine__header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="skin-routine__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="skin-routine__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.text != blank -%}
        <p class="skin-routine__text">{{ section.settings.text | escape }}</p>
      {%- endif -%}
    </div>

    <div class="skin-routine__grid">
      {%- for block in section.blocks -%}
        <a
          class="skin-routine__card"
          {% if block.settings.link != blank %}
            href="{{ block.settings.link }}"
          {% else %}
            role="link" aria-disabled="true"
          {% endif %}
          {{ block.shopify_attributes }}
        >
          <span class="skin-routine__number">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}</span>
          <div>
            {%- if block.settings.title != blank -%}
              <h3 class="skin-routine__card-title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="skin-routine__card-text">{{ block.settings.text | escape }}</p>
            {%- endif -%}
          </div>
          {%- if block.settings.tag != blank -%}
            <span class="skin-routine__tag">{{ block.settings.tag | escape }}</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>

    <div class="skin-routine__footer">
      {%- if section.settings.footer_note != blank -%}
        <p class="skin-routine__note">{{ section.settings.footer_note | escape }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a
          class="button button--primary skin-routine__button"
          {% if section.settings.button_link != blank %}
            href="{{ section.settings.button_link }}"
          {% else %}
            role="link" aria-disabled="true"
          {% endif %}
        >
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Skin Routine Guide",
  "tag": "section",
  "class": "section-skin-routine-guide",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Üst etiket",
      "default": "Cilt ihtiyacına göre keşfet"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Başlık",
      "default": "Rutinin nereden başlamalı?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Açıklama",
      "default": "Doğru ürünü seçmeyi kolaylaştıran kısa bir rehber: temizleme, nem, bariyer ve parlaklık adımlarını cildinin ihtiyacına göre eşleştir."
    },
    {
      "type": "textarea",
      "id": "footer_note",
      "label": "Alt not",
      "default": "Her ürün sayfasında cilt tipi, kullanım sırası ve aktif içerik bilgilerini birlikte görebilirsin."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Buton metni",
      "default": "Tüm ürünleri incele"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Buton linki"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Arka plan",
      "default": "#f7f1e8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Yazı rengi",
      "default": "#1f1711"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Vurgu rengi",
      "default": "#8f5f3c"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Üst boşluk",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Alt boşluk",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "routine_card",
      "name": "Rutin kartı",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Başlık",
          "default": "Nazik temizleme"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Açıklama",
          "default": "Cildi kurutmadan arındıran temizleyicilerle rutine sakin bir başlangıç yap."
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Etiket",
          "default": "Temizleyici"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Skin Routine Guide",
      "blocks": [
        {
          "type": "routine_card"
        },
        {
          "type": "routine_card",
          "settings": {
            "title": "Bariyer desteği",
            "text": "Nem kaybını azaltmaya ve cilt bariyerini daha konforlu hissettirmeye odaklanan bakım adımı.",
            "tag": "Krem"
          }
        },
        {
          "type": "routine_card",
          "settings": {
            "title": "Hedefli serum",
            "text": "Matlık, ton eşitsizliği veya hassasiyet gibi ihtiyaçlara aktif içeriklerle yanıt ver.",
            "tag": "Serum"
          }
        },
        {
          "type": "routine_card",
          "settings": {
            "title": "Günlük denge",
            "text": "Tonik ve destekleyici ürünlerle rutinin sonraki adımlarına cildi hazırla.",
            "tag": "Tonik"
          }
        }
      ]
    }
  ]
}
{% endschema %}
