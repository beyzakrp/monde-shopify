{%- liquid
  assign section_heading = section.settings.heading
  if section_heading == blank
    assign section_heading = collection.title
  endif

  assign visible_blocks = 0
  for block in section.blocks
    if block.settings.collection != blank or request.design_mode
      assign visible_blocks = visible_blocks | plus: 1
    endif
  endfor
-%}

{%- style -%}
  #special-collections-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  #special-collections-{{ section.id }} .special-collections__header {
    max-width: 760px;
    margin: 0 auto 28px;
    padding: 0 16px;
    text-align: {{ section.settings.heading_alignment }};
  }

  #special-collections-{{ section.id }} .special-collections__eyebrow {
    margin: 0 0 8px;
    font-family: var(--text-font-family, var(--font-body-family));
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    line-height: 1.3;
    text-transform: uppercase;
    color: rgba(47, 47, 47, 0.58);
  }

  #special-collections-{{ section.id }} .special-collections__title {
    margin: 0;
    font-family: Optima, 'Avenir LT Pro', var(--font-heading-family);
    font-size: clamp(28px, 3.2vw, 42px);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.08;
    color: #2f2f2f;
  }

  #special-collections-{{ section.id }} .special-collections__text {
    max-width: 58ch;
    margin: 12px auto 0;
    font-family: var(--text-font-family, var(--font-body-family));
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.65;
    color: rgba(47, 47, 47, 0.68);
  }

  #special-collections-{{ section.id }} .special-collections__grid {
    display: grid;
    grid-template-columns: repeat(var(--columns-mobile), minmax(0, 1fr));
    border-top: 1px solid rgba(47, 47, 47, 0.08);
    border-left: 1px solid rgba(47, 47, 47, 0.08);
    background: #fff;
  }

  #special-collections-{{ section.id }} .special-collection-card {
    position: relative;
    display: flex;
    min-width: 0;
    min-height: 100%;
    flex-direction: column;
    border-right: 1px solid rgba(47, 47, 47, 0.08);
    border-bottom: 1px solid rgba(47, 47, 47, 0.08);
    background: #fff;
    color: #2f2f2f;
    text-decoration: none;
  }

  #special-collections-{{ section.id }} .special-collection-card__media {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: {{ section.settings.image_ratio }};
    background: #f7f7f7;
  }

  #special-collections-{{ section.id }} .special-collection-card__image,
  #special-collections-{{ section.id }} .special-collection-card__placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  #special-collections-{{ section.id }} .special-collection-card__image {
    object-fit: cover;
    object-position: center;
    transition: transform 0.42s ease, filter 0.42s ease;
  }

  #special-collections-{{ section.id }} .special-collection-card__placeholder {
    background: #f7f7f7;
    fill: rgba(47, 47, 47, 0.18);
  }

  #special-collections-{{ section.id }} .special-collection-card:hover .special-collection-card__image,
  #special-collections-{{ section.id }} .special-collection-card:focus-visible .special-collection-card__image {
    transform: scale(1.035);
    filter: saturate(1.02) contrast(1.03);
  }

  #special-collections-{{ section.id }} .special-collection-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 4px 10px;
    background: #faf9f6;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    color: #2f2f2f;
    font-family: var(--text-font-family, var(--font-body-family));
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.9px;
    line-height: 13.5px;
    text-transform: uppercase;
  }

  #special-collections-{{ section.id }} .special-collection-card__info {
    display: flex;
    min-height: 100%;
    flex: 1 1 auto;
    flex-direction: column;
    padding: 14px 12px 18px;
    text-align: left;
  }

  #special-collections-{{ section.id }} .special-collection-card__title {
    margin: 0;
    font-family: var(--text-font-family, var(--font-body-family));
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.35;
    color: #000;
  }

  #special-collections-{{ section.id }} .special-collection-card__description {
    margin: 8px 0 0;
    font-family: var(--text-font-family, var(--font-body-family));
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.5;
    color: rgba(47, 47, 47, 0.68);
  }

  #special-collections-{{ section.id }} .special-collection-card__meta {
    margin-top: auto;
    padding-top: 12px;
    font-family: var(--text-font-family, var(--font-body-family));
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
    color: rgba(47, 47, 47, 0.5);
  }

  #special-collections-{{ section.id }} .special-collections__empty {
    margin: 0;
    padding: 32px 16px;
    text-align: center;
    color: rgba(47, 47, 47, 0.62);
  }

  @media screen and (min-width: 750px) {
    #special-collections-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    #special-collections-{{ section.id }} .special-collections__header {
      margin-bottom: 36px;
      padding: 0 40px;
    }

    #special-collections-{{ section.id }} .special-collections__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    }

    #special-collections-{{ section.id }} .special-collection-card__info {
      padding: 16px 14px 22px;
    }
  }
{%- endstyle -%}

{%- if visible_blocks > 0 or request.design_mode -%}
  <section
    id="special-collections-{{ section.id }}"
    class="special-collections color-{{ section.settings.color_scheme }} gradient"
  >
  {%- if section.settings.show_header and section_heading != blank -%}
    <div class="special-collections__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="special-collections__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      <h2 class="special-collections__title">{{ section_heading | escape }}</h2>

      {%- if section.settings.description != blank -%}
        <div class="special-collections__text rte">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if visible_blocks > 0 -%}
    <div
      class="special-collections__grid"
      style="--columns-mobile: {{ section.settings.columns_mobile }};"
    >
      {%- for block in section.blocks -%}
        {%- liquid
          assign card_collection = block.settings.collection
          if card_collection == blank and request.design_mode == false
            continue
          endif

          assign card_title = block.settings.title
          if card_title == blank and card_collection != blank
            assign card_title = card_collection.title
          endif
          if card_title == blank
            assign card_title = 'Koleksiyon seçin'
          endif

          assign card_image = block.settings.image
          if card_image == blank and card_collection.image != blank
            assign card_image = card_collection.image
          endif
          if card_image == blank and card_collection.featured_image != blank
            assign card_image = card_collection.featured_image
          endif

          assign card_description = block.settings.description
          if card_description == blank and card_collection.description != blank
            assign card_description = card_collection.description | strip_html | truncatewords: 18
          endif

          assign products_count = card_collection.all_products_count | default: card_collection.products_count
          assign card_url = card_collection.url | default: '#'
        -%}

        <a
          class="special-collection-card"
          href="{{ card_url }}"
          {% if card_collection == blank %}
            role="link" aria-disabled="true"
          {% endif %}
          {{ block.shopify_attributes }}
        >
          <span class="special-collection-card__media">
            {%- if block.settings.badge != blank -%}
              <span class="special-collection-card__badge">{{ block.settings.badge | escape }}</span>
            {%- endif -%}

            {%- if card_image != blank -%}
              {{
                card_image
                | image_url: width: 1400
                | image_tag:
                  widths: '320, 480, 640, 900, 1200, 1400',
                  sizes: '(min-width: 1200px) 25vw, (min-width: 750px) 33vw, 50vw',
                  class: 'special-collection-card__image',
                  loading: 'lazy',
                  alt: card_image.alt | default: card_title
              }}
            {%- else -%}
              {{ 'collection-apparel-1' | placeholder_svg_tag: 'special-collection-card__placeholder' }}
            {%- endif -%}
          </span>

          <span class="special-collection-card__info">
            <span class="special-collection-card__title">{{ card_title | escape }}</span>

            {%- if section.settings.show_description and card_description != blank -%}
              <span class="special-collection-card__description">{{ card_description | escape }}</span>
            {%- endif -%}

            {%- if card_collection != blank and section.settings.show_product_count -%}
              <span class="special-collection-card__meta">{{ products_count }} ürün</span>
            {%- elsif request.design_mode -%}
              <span class="special-collection-card__meta">Tema editöründe koleksiyon seçin</span>
            {%- endif -%}
          </span>
        </a>
      {%- endfor -%}
    </div>
  {%- elsif request.design_mode -%}
    <p class="special-collections__empty">Bu bölüme koleksiyon blokları ekleyin.</p>
  {%- endif -%}
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Special collections grid",
  "tag": "section",
  "class": "section special-collections-section",
  "max_blocks": 20,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Başlığı göster",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Üst başlık",
      "default": "GLAMFOX seçimleri"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Başlık",
      "info": "Boş bırakılırsa koleksiyon başlığı kullanılır."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Açıklama",
      "default": "<p>Cilt bakım rutininize göre hazırlanmış koleksiyonları keşfedin.</p>"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Başlık hizası",
      "options": [
        {
          "value": "left",
          "label": "Sol"
        },
        {
          "value": "center",
          "label": "Orta"
        },
        {
          "value": "right",
          "label": "Sağ"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Görsel oranı",
      "options": [
        {
          "value": "4 / 5",
          "label": "Portre"
        },
        {
          "value": "1 / 1",
          "label": "Kare"
        },
        {
          "value": "3 / 4",
          "label": "Uzun portre"
        }
      ],
      "default": "4 / 5"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Desktop kolon",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Mobil kolon",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Koleksiyon açıklamasını göster",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Ürün sayısını göster",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Renk şeması",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Üst boşluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Alt boşluk",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Koleksiyon",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Koleksiyon"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Kart etiketi",
          "placeholder": "Örn: Serum"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Özel başlık",
          "info": "Boş bırakılırsa koleksiyon başlığı kullanılır."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Özel görsel",
          "info": "Boş bırakılırsa koleksiyon görseli kullanılır."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Kısa açıklama",
          "info": "Boş bırakılırsa koleksiyon açıklaması kullanılır."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Special collections grid",
      "blocks": [
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}
