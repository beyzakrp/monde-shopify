{%- style -%}
  #home-banner-{{ section.id }} {
    position: relative;
    overflow: hidden;
    min-height: {{ section.settings.min_height_mobile }}px;
    background: #e8dfd4;
  }

  #home-banner-{{ section.id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 72% 44%, rgba(255, 217, 176, 0.18), transparent 44%),
      linear-gradient(180deg, rgba(12, 8, 6, {{ section.settings.overlay_strength | divided_by: 220.0 }}) 0%, rgba(12, 8, 6, {{ section.settings.overlay_strength | divided_by: 170.0 }}) 42%, rgba(12, 8, 6, {{ section.settings.overlay_strength | divided_by: 130.0 }}) 100%);
    z-index: 1;
    pointer-events: none;
  }

  #home-banner-{{ section.id }} .banner__image--desktop {
    width: 100%;
    height: clamp(620px, 87vh, 920px);
    display: block;
    object-fit: cover;
    object-position: {{ section.settings.image_position }};
  }

  #home-banner-{{ section.id }} .banner__image--mobile {
    width: 100%;
    display: none;
    object-fit: cover;
  }

  #home-banner-{{ section.id }} .banner__content--desktop {
    position: absolute;
    top: 54%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: min(860px, 90vw);
    z-index: 3;
    text-align: center;
  }

  #home-banner-{{ section.id }} .banner__content--desktop.is-left {
    left: clamp(1.6rem, 5vw, 6rem);
    transform: translate(0, -50%);
    align-items: flex-start;
    text-align: left;
  }

  #home-banner-{{ section.id }} .banner__content--desktop.is-center {
    left: 50%;
    transform: translate(-50%, -50%);
    align-items: center;
    text-align: center;
  }

  #home-banner-{{ section.id }} .banner__content--desktop.is-right {
    left: auto;
    right: clamp(1.6rem, 5vw, 6rem);
    transform: translate(0, -50%);
    align-items: flex-end;
    text-align: right;
  }

  #home-banner-{{ section.id }} .banner__content--desktop.is-left .banner__campaign,
  #home-banner-{{ section.id }} .banner__content--desktop.is-left .banner__heading,
  #home-banner-{{ section.id }} .banner__content--desktop.is-left .banner__subtext {
    text-align: left;
  }

  #home-banner-{{ section.id }} .banner__content--desktop.is-right .banner__campaign,
  #home-banner-{{ section.id }} .banner__content--desktop.is-right .banner__heading,
  #home-banner-{{ section.id }} .banner__content--desktop.is-right .banner__subtext {
    text-align: right;
  }

  #home-banner-{{ section.id }} .banner__content--desktop.is-center .banner__campaign,
  #home-banner-{{ section.id }} .banner__content--desktop.is-center .banner__heading,
  #home-banner-{{ section.id }} .banner__content--desktop.is-center .banner__subtext {
    text-align: center;
  }

  #home-banner-{{ section.id }} .banner__campaign {
    margin: 0 0 1.4rem;
    font-family: 'Avenir LT Pro', 'Segoe UI', sans-serif;
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.26em;
    color: rgba(250, 238, 222, 0.88);
    font-weight: 600;
  }

  #home-banner-{{ section.id }} .banner__heading {
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.heading_color }};
    font-family: '{{ section.settings.heading_font }}', 'Times New Roman', serif;
    line-height: 0.98;
    letter-spacing: 0.005em;
    text-align: center;
    text-wrap: balance;
    margin: 0 0 2rem;
    max-width: 11.5ch;
    text-shadow: 0 7px 26px rgba(0, 0, 0, 0.23);
  }

  #home-banner-{{ section.id }} .banner__subtext {
    font-size: {{ section.settings.subtext_size }}px;
    color: {{ section.settings.subtext_color }};
    line-height: 1.55;
    letter-spacing: 0.01em;
    text-align: center;
    font-family: 'Avenir LT Pro', 'Segoe UI', sans-serif;
    max-width: 34ch;
    margin: 0 0 3.2rem;
    padding: 0;
    font-weight: 500;
    text-shadow: 0 5px 18px rgba(0, 0, 0, 0.25);
  }

  #home-banner-{{ section.id }} .banner__buttons {
    display: flex;
    gap: {{ section.settings.button_gap }}px;
    flex-wrap: wrap;
    justify-content: center;
  }

  #home-banner-{{ section.id }} .banner__btn--primary {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 200px;
    height: 48px;
    font-size: 14px;
    font-family: 'Avenir LT Pro', sans-serif;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background-color 0.25s ease, color 0.25s ease, border-color 0.25s ease;
    background-color: {{ section.settings.btn1_bg }};
    color: {{ section.settings.btn1_text }};
    border: 1px solid {{ section.settings.btn1_bg }};
    border-radius: 999px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0 2.4rem;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.24);
  }

  #home-banner-{{ section.id }} .banner__btn--primary:hover {
    transform: translateY(-2px) scale(1.01);
    background-color: #ffffff;
    color: #1d150f;
    border-color: #ffffff;
  }

  #home-banner-{{ section.id }} .banner__btn--secondary {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 200px;
    height: 48px;
    font-size: 14px;
    font-family: 'Avenir LT Pro', sans-serif;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.25s ease, background-color 0.25s ease, color 0.25s ease, border-color 0.25s ease;
    background-color: {{ section.settings.btn2_bg }};
    color: {{ section.settings.btn2_text }};
    border: 1px solid {{ section.settings.btn2_border }};
    border-radius: 999px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0 2.4rem;
  }

  #home-banner-{{ section.id }} .banner__btn--secondary:hover {
    transform: translateY(-2px) scale(1.01);
    background-color: rgba(255, 255, 255, 0.2);
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.95);
  }

  #home-banner-{{ section.id }} .banner__scroll-cue {
    position: absolute;
    left: 50%;
    bottom: clamp(20px, 5vh, 42px);
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    color: rgba(252, 242, 229, 0.92);
    letter-spacing: 0.18em;
    font-size: 1.08rem;
    font-family: 'Avenir LT Pro', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
  }

  #home-banner-{{ section.id }} .banner__scroll-line {
    width: 1px;
    height: 34px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.95));
  }

  #home-banner-{{ section.id }} .banner__content--mobile {
    display: none;
    position: absolute;
    bottom: 28px;
    left: 0;
    right: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 2;
    padding: 0 1.6rem;
    text-align: center;
  }

  #home-banner-{{ section.id }} .banner__heading--mobile {
    font-size: {{ section.settings.heading_size_mobile }}px;
    color: {{ section.settings.heading_color_mobile }};
    font-family: '{{ section.settings.heading_font }}', 'Times New Roman', serif;
    line-height: 1.03;
    letter-spacing: 0.01em;
    text-align: center;
    margin: 0 0 1.2rem;
    text-shadow: 0 6px 20px rgba(0, 0, 0, 0.25);
  }

  #home-banner-{{ section.id }} .banner__subtext--mobile {
    font-size: 1.5rem;
    color: {{ section.settings.subtext_color_mobile }};
    line-height: 1.5;
    text-align: center;
    margin: 0 0 2rem;
    max-width: 30ch;
  }

  #home-banner-{{ section.id }} .banner__btn--mobile {
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(320px, 85vw);
    height: 46px;
    font-size: 14px;
    font-family: 'Avenir LT Pro', sans-serif;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    background-color: {{ section.settings.btn1_bg }};
    color: {{ section.settings.btn1_text }};
    border: 1px solid {{ section.settings.btn1_bg }};
    border-radius: 999px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 10px;
    transition: transform 0.2s ease, background-color 0.2s ease, color 0.2s ease;
  }

  #home-banner-{{ section.id }} .banner__btn--mobile:hover {
    transform: translateY(-1px) scale(1.01);
  }

  #home-banner-{{ section.id }} .banner__btn--mobile-secondary {
    background: transparent;
    color: {{ section.settings.btn2_text }};
    border-color: {{ section.settings.btn2_border }};
  }

  {% if section.settings.mobile_gradient %}
  #home-banner-{{ section.id }}::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(15, 11, 9, 0.68) 0%, rgba(15, 11, 9, 0.2) 58%, transparent 82%);
    pointer-events: none;
    z-index: 2;
  }
  {% endif %}

  @media screen and (max-width: 1008px) {
    #home-banner-{{ section.id }} .banner__image--desktop { display: none; }
    #home-banner-{{ section.id }} .banner__image--mobile { display: block; }
    #home-banner-{{ section.id }} .banner__image--mobile { min-height: {{ section.settings.min_height_mobile }}px; object-fit: cover; }
    #home-banner-{{ section.id }} .banner__content--desktop { display: none !important; }
    #home-banner-{{ section.id }} .banner__content--mobile { display: flex; }
    #home-banner-{{ section.id }} .banner__scroll-cue { display: none; }
  }

  @media screen and (max-width: 1250px) {
    #home-banner-{{ section.id }} .banner__buttons {
      gap: 10px;
    }
    #home-banner-{{ section.id }} .banner__heading {
      font-size: {{ section.settings.heading_size | times: 0.75 | round }}px;
    }
  }

  /* Overlay badge that can be positioned from the section panel */
  #home-banner-{{ section.id }} .banner__overlay {
    position: absolute;
    z-index: 1;
    pointer-events: none;
    will-change: transform;
    display: grid;
    place-items: center;
  }

  #home-banner-{{ section.id }} .banner__overlay svg,
  #home-banner-{{ section.id }} .banner__overlay img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* only rotate the text ring, keep image/static elements unrotated */
  #home-banner-{{ section.id }} .banner__overlay__text {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    pointer-events: none;
  }

  #home-banner-{{ section.id }} .banner__overlay.is-rotating .banner__overlay__text {
    animation-name: banner-badge-spin;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-duration: var(--badge-rotation-duration, 12s);
  }

  /* outer (rotating) and inner (static) image styles */
  #home-banner-{{ section.id }} .banner__overlay__outer {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
  }

  #home-banner-{{ section.id }} .banner__overlay.is-rotating .banner__overlay__outer {
    /* rotate the inner image element so the wrapper's translate is preserved */
  }

  #home-banner-{{ section.id }} .banner__overlay__outer-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transform-origin: 50% 50%;
  }

  #home-banner-{{ section.id }} .banner__overlay.is-rotating .banner__overlay__outer-img {
    animation-name: banner-badge-spin;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-duration: var(--badge-rotation-duration, 12s);
  }

  #home-banner-{{ section.id }} .banner__overlay__inner {
    position: absolute;
    display: block;
    pointer-events: none;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  @keyframes banner-badge-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* position helpers */
  #home-banner-{{ section.id }} .banner__overlay--top-left { top: 8%; left: 6%; }
  #home-banner-{{ section.id }} .banner__overlay--top-right { top: 8%; right: 6%; }
  #home-banner-{{ section.id }} .banner__overlay--center { top: 50%; left: 50%; transform: translate(-50%, -50%); }
  #home-banner-{{ section.id }} .banner__overlay--bottom-left { bottom: 8%; left: 6%; }
  #home-banner-{{ section.id }} .banner__overlay--bottom-right { bottom: 8%; right: 6%; }
{%- endstyle -%}

<section id="home-banner-{{ section.id }}">
  <div style="position: relative;">
    <picture>
      {%- if section.settings.desktop_image != blank -%}
        {{ section.settings.desktop_image | image_url: width: 1920 | image_tag:
          class: 'banner__image--desktop',
          widths: '768, 1024, 1440, 1920',
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'high',
          alt: section.settings.desktop_image.alt | default: shop.name
        }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'banner__image--desktop placeholder' }}
      {%- endif -%}

      {%- if section.settings.mobile_image != blank -%}
        {{ section.settings.mobile_image | image_url: width: 800 | image_tag:
          class: 'banner__image--mobile',
          widths: '390, 480, 768',
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'high',
          alt: section.settings.mobile_image.alt | default: shop.name
        }}
      {%- elsif section.settings.desktop_image != blank -%}
        {{ section.settings.desktop_image | image_url: width: 800 | image_tag:
          class: 'banner__image--mobile',
          widths: '390, 480, 768',
          sizes: '100vw',
          loading: 'eager',
          alt: section.settings.desktop_image.alt | default: shop.name
        }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'banner__image--mobile placeholder' }}
      {%- endif -%}
    </picture>

    <!-- Desktop Content -->
    <div class="banner__content--desktop is-{{ section.settings.desktop_content_side }}">
      {%- if section.settings.campaign_label != blank -%}
        <p class="banner__campaign">{{ section.settings.campaign_label }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }} class="banner__heading">
          {{ section.settings.heading }}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="banner__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}

      <div class="banner__buttons">
        {%- if section.settings.btn1_label != blank -%}
          <a href="{{ section.settings.btn1_link }}" class="banner__btn--primary">
            {{ section.settings.btn1_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.btn2_label != blank -%}
          <a href="{{ section.settings.btn2_link }}" class="banner__btn--secondary">
            {{ section.settings.btn2_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <!-- Mobile Content -->
    <div class="banner__content--mobile">
      {%- if section.settings.campaign_label != blank -%}
        <p class="banner__campaign">{{ section.settings.campaign_label }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }} class="banner__heading--mobile">
          {{ section.settings.heading }}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="banner__subtext--mobile">{{ section.settings.subtext }}</p>
      {%- endif -%}

      {%- if section.settings.btn1_label != blank -%}
        <a href="{{ section.settings.btn1_link }}" class="banner__btn--mobile">
          {{ section.settings.btn1_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.btn2_label != blank -%}
        <a href="{{ section.settings.btn2_link }}" class="banner__btn--mobile banner__btn--mobile-secondary">
          {{ section.settings.btn2_label }}
        </a>
      {%- endif -%}
    </div>

    {%- if section.settings.scroll_label != blank -%}
      <div class="banner__scroll-cue" aria-hidden="true">
        <span>{{ section.settings.scroll_label }}</span>
        <span class="banner__scroll-line"></span>
      </div>
    {%- endif -%}

    {%- if section.settings.overlay_enable -%}
      {%- assign pos = section.settings.overlay_position -%}
      <div
        class="banner__overlay banner__overlay--{{ pos }} {% if section.settings.overlay_rotate %}is-rotating{% endif %}"
        style="width: {{ section.settings.overlay_size }}px; height: {{ section.settings.overlay_size }}px; {% if pos == 'center' %}left:50%; top:50%; transform: translate(calc(-50% + {{ section.settings.overlay_offset_x }}px), calc(-50% + {{ section.settings.overlay_offset_y }}px));{% else %}{% if pos contains 'left' %}left:6%;{% else %}right:6%;{% endif %}{% if pos contains 'top' %}top:8%;{% else %}bottom:8%;{% endif %} transform: translate({{ section.settings.overlay_offset_x }}px, {{ section.settings.overlay_offset_y }}px);{% endif %} --badge-rotation-duration: {{ section.settings.overlay_rotate_speed }}s;">

        <!-- Inline SVG badge (keeps crisp vector) -->
        <!-- You can replace this markup or add options to swap it for an uploaded image -->
        <div class="banner__overlay__svg">
          <!-- user-provided SVG -->
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 611 623" fill="none" aria-hidden="true">
            <!-- simplified: embed the provided SVG content trimmed for brevity -->
            <!-- full SVG content inserted here -->
            
            <!-- fallback/outer graphic: user may upload inner image below -->
            <g>
             
            </g>
          </svg>
        </div>

        <!-- outer rotating image (badge text) -->
        {% if section.settings.overlay_outer_image != blank %}
          <div class="banner__overlay__outer" aria-hidden="true">
            <img class="banner__overlay__outer-img" src="{{ section.settings.overlay_outer_image | image_url: 'master' }}" width="{{ section.settings.overlay_size }}" height="{{ section.settings.overlay_size }}" alt="" />
          </div>
        {% else %}
          <div class="banner__overlay__outer" aria-hidden="true">
            <img class="banner__overlay__outer-img" src="https://cdn.shopify.com/s/files/1/0734/7001/7730/files/bagde-text.png?v=1777970007" width="{{ section.settings.overlay_size }}" height="{{ section.settings.overlay_size }}" alt="" />
          </div>
        {% endif %}

        <!-- inner static image (flag) centered over the rotating outer badge -->
        {% assign inner_px = section.settings.overlay_size | times: section.settings.overlay_inner_scale | divided_by: 100 %}
        {% if section.settings.overlay_inner_image != blank %}
          <img style="padding: 20px;", class="banner__overlay__inner" src="{{ section.settings.overlay_inner_image | image_url: 'master' }}" width="{{ inner_px }}" height="{{ inner_px }}" alt="" />
        {% else %}
          <img style="padding: 20px;", class="banner__overlay__inner" src="https://cdn.shopify.com/s/files/1/0734/7001/7730/files/korean-flag-png.png?v=1777969830" width="{{ inner_px }}" height="{{ inner_px }}" alt="" />
        {% endif %}

        <!-- rotating text (keeps image static) -->
        <div class="banner__overlay__text">
          <span class="banner__overlay__text-content">{{ section.settings.overlay_text }}</span>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Home Banner",
  "tag": "section",
  "class": "home-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Görseller"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Görsel"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobil Görsel (opsiyonel, boş bırakılırsa desktop kullanılır)"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Görsel Pozisyonu",
      "options": [
        { "value": "center center", "label": "Orta" },
        { "value": "top center", "label": "Üst" },
        { "value": "bottom center", "label": "Alt" },
        { "value": "center left", "label": "Sol" },
        { "value": "center right", "label": "Sağ" }
      ],
      "default": "bottom center"
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "label": "Mobil Minimum Yükseklik",
      "min": 300,
      "max": 700,
      "step": 10,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "overlay_strength",
      "label": "Gradient yoğunluğu",
      "min": 10,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 55
    },
    {
      "type": "header",
      "content": "İçerik"
    },
    {
      "type": "text",
      "id": "campaign_label",
      "label": "Ust etiket metni",
      "default": "NEW SEASON CAMPAIGN"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Başlık",
      "default": "The Glow of Eternity"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Başlık HTML Etiketi",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "p", "label": "Paragraf" }
      ],
      "default": "h1"
    },
    {
      "type": "text",
      "id": "heading_font",
      "label": "Başlık Font Adı",
      "default": "Cormorant Garamond",
      "info": "Sistemde yüklü olan font adını girin"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Başlık Font Boyutu (Desktop)",
      "min": 24,
      "max": 90,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Başlık Font Boyutu (Mobil)",
      "min": 18,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Başlık Rengi (Desktop)",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color_mobile",
      "label": "Başlık Rengi (Mobil)",
      "default": "#ffffff"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Alt Metin",
      "default": "A dialogue between light and skin. Our new formula awakens your innate luminosity."
